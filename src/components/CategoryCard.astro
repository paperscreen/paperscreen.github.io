---
const { category } = Astro.props;
---
<article class="overflow-hidden rounded-3xl border border-neutral-200 bg-white p-6 transition hover:-translate-y-1 hover:shadow-soft">
  <p class="text-sm uppercase tracking-[0.24em] text-neutral-500">{category.tag}</p>
  <h3 class="mt-4 text-xl font-semibold text-slate-950">{category.title}</h3>
  <p class="mt-3 text-sm leading-6 text-slate-600">{category.description}</p>
  <a class="mt-5 inline-flex text-sm font-semibold text-accent transition hover:text-slate-950" href={category.href}>Browse</a>
</article>
