---
const { review } = Astro.props;
---
<article class="overflow-hidden rounded-3xl border border-neutral-200 bg-white p-6 transition hover:-translate-y-1 hover:shadow-soft">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-[0.24em] text-neutral-500">Review</p>
      <h3 class="mt-3 text-xl font-semibold text-slate-950">{review.title}</h3>
      <p class="mt-3 text-sm leading-6 text-slate-600">{review.description}</p>
    </div>
    <span class="rounded-full bg-neutral-100 px-3 py-1 text-sm font-semibold text-slate-700">{review.score ? `${review.score}/10` : 'Expert'}</span>
  </div>
  <div class="mt-6 flex flex-wrap gap-2 text-xs text-neutral-500">
    <span>{review.author}</span>
    <span>•</span>
    <span>{new Date(review.pubDate).toLocaleDateString()}</span>
  </div>
</article>
