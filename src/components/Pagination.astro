---
const { previous, next } = Astro.props;
---
<div class="flex flex-col gap-3 rounded-3xl border border-neutral-200 bg-white p-6 sm:flex-row sm:items-center sm:justify-between">
  {previous ? (
    <a class="rounded-full border border-neutral-200 px-4 py-2 text-sm font-medium text-slate-950 transition hover:bg-neutral-100" href={previous.href}>← {previous.label}</a>
  ) : <span class="text-sm text-neutral-500">No previous page</span>}
  {next ? (
    <a class="rounded-full border border-neutral-200 px-4 py-2 text-sm font-medium text-slate-950 transition hover:bg-neutral-100" href={next.href}>{next.label} →</a>
  ) : <span class="text-sm text-neutral-500">No next page</span>}
</div>
