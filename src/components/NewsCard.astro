---
const { item } = Astro.props;
---
<article class="overflow-hidden rounded-3xl border border-neutral-200 bg-white p-6 transition hover:-translate-y-1 hover:shadow-soft">
  <p class="text-xs uppercase tracking-[0.24em] text-neutral-500">News</p>
  <h3 class="mt-3 text-xl font-semibold text-slate-950">{item.title}</h3>
  <p class="mt-3 text-sm leading-6 text-slate-600">{item.description}</p>
  <div class="mt-5 flex items-center justify-between text-xs text-neutral-500">
    <span>{item.source ?? item.author}</span>
    <span>{new Date(item.pubDate).toLocaleDateString()}</span>
  </div>
</article>
