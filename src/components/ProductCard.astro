---
const { product } = Astro.props;
---
<article class="group overflow-hidden rounded-3xl border border-neutral-200 bg-white transition hover:-translate-y-1 hover:shadow-soft">
  <div class="bg-neutral-100 px-5 py-6">
    <p class="text-sm uppercase tracking-[0.24em] text-neutral-500">{product.category}</p>
    <h3 class="mt-4 text-xl font-semibold text-slate-950">{product.title}</h3>
    <p class="mt-3 text-sm leading-6 text-slate-600">{product.description}</p>
  </div>
  <div class="flex items-center justify-between gap-4 border-t border-neutral-200 px-5 py-4">
    <span class="text-sm font-medium text-slate-950">{product.priceRange ?? 'Price range available'}</span>
    <a class="text-sm font-semibold text-accent transition group-hover:text-slate-950" href={product.href ?? '#'}>Explore</a>
  </div>
</article>
