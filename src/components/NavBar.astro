---
const navItems = [
  { label: 'Products', href: '/products' },
  { label: 'Reviews', href: '/reviews' },
  { label: 'Comparisons', href: '/comparisons' },
  { label: 'News', href: '/news' },
  { label: 'Guides', href: '/guides' }
];
---
<header class="border-b border-neutral-200 bg-white/95 backdrop-blur-sm sticky top-0 z-40">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 sm:px-6">
    <a class="font-display text-xl font-semibold tracking-tight text-slate-950" href="/">PaperScreen</a>
    <nav class="hidden items-center gap-8 md:flex">
      {navItems.map((item) => (
        <a class="text-sm font-medium text-slate-700 transition hover:text-slate-950" href={item.href}>{item.label}</a>
      ))}
    </nav>
    <a class="inline-flex items-center rounded-full border border-neutral-200 bg-white px-4 py-2 text-sm font-medium text-slate-900 shadow-sm transition hover:border-accent hover:text-accent" href="/about">About</a>
  </div>
</header>
