---
const { headline, description, actionLabel, actionHref } = Astro.props;
---
<section class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
  <div class="rounded-[32px] border border-neutral-200 bg-neutral-950/95 p-8 shadow-soft backdrop-blur-sm sm:p-10">
    <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-green-300">Stay informed</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Newsletter for display technology and product launches.</h2>
        <p class="mt-4 max-w-xl text-sm leading-7 text-neutral-300">Get curated reviews, buying guides, and news about reflective screens delivered once per week.</p>
      </div>
      <div class="rounded-3xl bg-white p-6 text-center">
        <p class="text-sm font-medium text-slate-950">Premium newsletter</p>
        <a class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" href={actionHref}>{actionLabel}</a>
      </div>
    </div>
  </div>
</section>
