---
const { headline, intro, actions } = Astro.props;
---
<section class="relative overflow-hidden bg-gradient-to-br from-white via-neutral-100 to-white px-5 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div class="space-y-8">
        <p class="inline-flex rounded-full border border-accent/20 bg-accent/10 px-4 py-1.5 text-sm font-semibold uppercase tracking-[0.24em] text-accent">Display intelligence</p>
        <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">PaperScreen: the future of eye-friendly and reflective display technology.</h1>
        <p class="max-w-2xl text-base leading-8 text-slate-600">Deep coverage of E-Ink, RLCD, reflective LCD, color e-paper, and transflective panels — designed to help readers discover the best premium devices for low-power, low-glare experiences.</p>
        <div class="flex flex-col gap-3 sm:flex-row">
          {actions.map((action) => (
            <a class="inline-flex items-center justify-center rounded-full bg-slate-950 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" href={action.href}>{action.label}</a>
          ))}
        </div>
      </div>
      <div class="relative">
        <div class="rounded-[36px] border border-neutral-200 bg-white p-6 shadow-soft">
          <div class="space-y-6">
            <div class="rounded-3xl bg-neutral-100 p-6">
              <p class="text-sm uppercase tracking-[0.24em] text-neutral-500">Spotlight</p>
              <h2 class="mt-3 text-2xl font-semibold text-slate-950">Color E-Ink panels are finally ready for premium devices.</h2>
              <p class="mt-3 text-sm leading-6 text-slate-600">Our expert review shows the best hardware, battery tradeoffs, and real-world contrast for modern digital paper experiences.</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="rounded-3xl border border-neutral-200 bg-white p-5">
                <p class="text-xs uppercase tracking-[0.24em] text-neutral-500">Trend</p>
                <p class="mt-2 font-semibold text-slate-950">Reflective LCD devices</p>
              </div>
              <div class="rounded-3xl border border-neutral-200 bg-white p-5">
                <p class="text-xs uppercase tracking-[0.24em] text-neutral-500">Guide</p>
                <p class="mt-2 font-semibold text-slate-950">Buying the best lightweight readers</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
