---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---
<BaseLayout title="About" description="About PaperScreen: a premium publication for reflective and eye-friendly display technologies." canonical="https://paperscreen.example/about">
  <NavBar />
  <main class="mx-auto max-w-4xl px-5 py-16 sm:px-6 lg:px-8">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'About' }]} />
    <section class="mt-10 space-y-10 rounded-[36px] border border-neutral-200 bg-white p-10 shadow-soft">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-accent">About PaperScreen</p>
        <h1 class="mt-4 text-4xl font-semibold text-slate-950">Premium coverage of modern paper-like displays.</h1>
      </div>
      <div class="grid gap-10 lg:grid-cols-2">
        <div class="space-y-4 text-slate-600">
          <p>PaperScreen is a content-first destination for displays that reduce eye strain, improve outdoor visibility, and unlock new battery-efficient form factors. We serve readers who value smart hardware choices and future-ready screen technology.</p>
          <p>Our editorial focus covers e-paper, color E-Ink, transflective panels, RLCD, and reflective LCD devices from laptops to dedicated readers. Every story is built to help you understand the practical tradeoffs and real world benefits.</p>
        </div>
        <div class="space-y-4 text-slate-600">
          <p>We design with clarity, speed, and accessibility in mind: neutral layouts, generous whitespace, and thoughtful interactions. The website is built on Astro and Tailwind so it stays lightweight, scalable, and ready for future commerce features.</p>
          <p>PaperScreen is structured to support product pages, affiliate links, and a more interactive storefront without compromising content quality or performance.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
